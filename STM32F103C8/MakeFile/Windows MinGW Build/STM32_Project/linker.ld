ENTRY(Reset_Handler)

_estack = 0x20005000;

MEMORY {
    FLASH (rx)  : ORIGIN = 0x08000000, LENGTH = 64K
    RAM   (xrw) : ORIGIN = 0x20000000, LENGTH = 20K
}

SECTIONS {
    .isr_vector : {
        . = ALIGN(4);
        KEEP(*(.isr_vector))
        . = ALIGN(4);
    } > FLASH
    
    .text : {
        . = ALIGN(4);
        *(.text)
        *(.text.*)
        *(.data)
        *(.data.*)
        . = ALIGN(4);
    } > FLASH

    _la_data = LOADADDR(.data);

    .data :
    {
        . = ALIGN(4);
        _sdata = .;        
        *(.data)
        *(.data.*)
        . = ALIGN(4);
        _edata = .;       
    } > RAM AT > FLASH

    .bss : {
        . = ALIGN(4);
        _sbss = .;
        *(.bss)
        *(.bss.*)
        *(COMMON)
        . = ALIGN(4);
        _ebss = .;
    } > RAM
}